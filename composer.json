{
    "name": "clubsuite/core",
    "description": "ClubSuite Core - Zentrale Vereinsverwaltung für Nextcloud",
    "license": "AGPL-3.0-or-later",
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "nextcloud/coding-standard": "^1.2"
    },
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "OCA\\ClubSuiteCore\\": "lib/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.1"
        }
    }
}
